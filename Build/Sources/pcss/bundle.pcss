@charset "UTF-8";

/* Using the folder "ts" as base source */
@import "tailwindcss" source("../ts");

/* Add template paths of TYPO3 extensions using TailwindCSS to source */
@source "../../../../phka_sitepackage/Resources/Private";

/* Importing PostCSS files */
@import "./_theme.pcss" layer(theme);
@import "./_base-styles.pcss" layer(base);
@import "./_components.pcss" layer(components);
@import "./_utilities.pcss" layer(utilities);
