{
  "name": "phka-frontend",
  "version": "1.0.0",
  "private": true,
  "targets": {
    "js-web": {
      "context": "browser",
      "isLibrary": false,
      "source": "./Sources/ts/bundle.ts",
      "distDir": "../Resources/Public/JavaScript/",
      "optimize": true,
      "sourceMap": true,
      "scopeHoist": false
    },
    "css-web": {
      "context": "browser",
      "isLibrary": false,
      "source": "./Sources/pcss/bundle.pcss",
      "distDir": "../Resources/Public/Css/",
      "optimize": true,
      "sourceMap": true,
      "scopeHoist": false
    },
    "css-fonts": {
      "context": "browser",
      "isLibrary": false,
      "source": [
        "./Sources/pcss/fonts/bundle.pcss"
      ],
      "distDir": "../Resources/Public/Fonts",
      "optimize": true,
      "sourceMap": true,
      "scopeHoist": false
    },
    "css-rte": {
      "context": "browser",
      "isLibrary": false,
      "source": [
        "./Sources/pcss/rte/custom.pcss"
      ],
      "distDir": "../Resources/Public/Css/Rte",
      "optimize": true,
      "sourceMap": true,
      "scopeHoist": false
    }
  },
  "browserslist": "defaults",
  "scripts": {
    "clean": "del-cli -f ./.parcel-cache ../Resources/Public/Css/ ../Resources/Public/Fonts/ ../Resources/Public/JavaScript/ ../Resources/Public/Icons/Frontend/",
    "build": "npm-run-all -s clean build:icons build:parcel",
    "build:parcel": "parcel build",
    "build:css": "parcel build --target css-web --target css-rte --target css-fonts",
    "build:css-web": "parcel build --target css-web",
    "build:css-rte": "parcel build --target css-rte",
    "build:css-fonts": "parcel build --target css-fonts",
    "build:js": "parcel build --target js-web",
    "build:js-web": "parcel build --target js-web",
    "build:icons": "cpy ./node_modules/lucide-static/icons/*.svg ../Resources/Public/Icons/Frontend",
    "watch": "npm-run-all -p watch:css watch:js",
    "watch:css": "npm-run-all -p watch:css-web watch:css-rte",
    "watch:css-web": "nodemon --watch ../Resources/Private/ --ext html --delay 2.5 --exec parcel watch ./Sources/bundle.pcss --dist-dir ../Resources/Public/Css/ --no-cache --no-hmr",
    "watch:css-rte": "parcel watch ./Sources/pcss/rte/* --dist-dir ../Resources/Public/Css/rte --no-cache --no-hmr",
    "watch:js": "npm-run-all -p watch:js-web",
    "watch:js-web": "parcel watch ./Sources/bundle.js --dist-dir ../Resources/Public/JavaScript/ --no-cache --no-hmr",
    "lint": "eslint ./Sources/ --flag unstable_ts_config",
    "check": "tsc ./Sources/js/bundle.ts --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Oliver Schmidt",
  "license": "GPL-2.0-or-later",
  "description": "",
  "devDependencies": {
    "@alpinejs/collapse": "^3.14.1",
    "@alpinejs/focus": "^3.14.1",
    "@alpinejs/persist": "^3.14.1",
    "@alpinejs/ui": "^3.14.1-beta.0",
    "@eslint/js": "^9.11.1",
    "@fontsource/source-code-pro": "^5.1.0",
    "@fontsource/source-sans-pro": "^5.1.0",
    "@fontsource/source-serif-pro": "^5.1.0",
    "@parcel/types": "^2.12.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@types/alpinejs": "^3.13.10",
    "@types/alpinejs__collapse": "^3.13.4",
    "@types/alpinejs__focus": "^3.13.4",
    "@types/alpinejs__persist": "^3.13.4",
    "@types/node": "^22.7.4",
    "alpinejs": "^3.14.1",
    "autoprefixer": "^10.4.20",
    "buffer": "^6.0.3",
    "cpy-cli": "^5.0.0",
    "crypto-browserify": "^3.12.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.11.1",
    "events": "^3.3.0",
    "globals": "^16.0.0",
    "lodash-es": "^4.17.21",
    "lucide-static": "^0.486.0",
    "nodemon": "^3.0.7",
    "npm-run-all": "^4.1.5",
    "os-browserify": "^0.3.0",
    "parcel": "^2.12.0",
    "path-browserify": "^1.0.1",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^10.0.5",
    "postcss-url": "^10.1.3",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.13",
    "typescript-eslint": "^8.8.0"
  }
}
